# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Environment secrets — never commit real .env
.env
.env.local
.env.*.local

# Build output
build/
.vite/

# Logs
*.log

# Uploaded/pasted assets (Replit agent scratchpad)
attached_assets/

# Keep these — do NOT add to gitignore:
# README.md
# docs/
# setup-local.md
# setup-production.md
# .env.example
# artifacts/api-server/data/csv/
# artifacts/api-server/data/logger-settings.json
# artifacts/api-server/data/users.json
