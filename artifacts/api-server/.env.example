PORT=3001

# Path to the folder containing sensor CSV files.
# Resolved relative to the project root (monorepo root, two levels above artifacts/api-server).
# Default: DB/CSV_Files
CSV_DATA_DIR=DB/CSV_Files

# GitHub Personal Access Token — store in Replit Secrets, never in this file.
# Required only for publishing to GitHub (see README "Publishing to GitHub").
# GITHUB_TOKEN=ghp_...
