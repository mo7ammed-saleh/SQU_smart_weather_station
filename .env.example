# Smart Weather Station Dashboard environment template

# Backend server
PORT=8080
NODE_ENV=development
HTTP_LOGS=false

# Frontend dashboard
FRONTEND_PORT=20300
BASE_PATH=/

# Final CSV source used by the dashboard
# Python DBD-to-CSV updater must save/replace the four sensor CSV files here.
CSV_DATA_DIR=DB/CSV_Files

# Local JSON data files
USERS_FILE=artifacts/api-server/data/users.json
LOGGER_SETTINGS_FILE=artifacts/api-server/data/logger-settings.json

# Default bootstrap credentials. Runtime login uses users.json.
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123

# DT80W direct logger control
# Keep disabled while the physical logger is not connected.
# When connected and tested, set DT80_ENABLED=true and DT80_MODE=tcp.
DT80_ENABLED=false
DT80_MODE=dry-run
DT80_IP=192.168.5.50
DT80_PORT=7700
DT80_TIMEOUT_MS=10000
DT80_JOB_NAME=S_W_STAT
DT80_APPLY_FULL_JOB=false

# Optional DeTransfer CLI mode, only when installed/configured on the host PC.
DETTRANSFER_EXE=
DETTRANSFER_PROFILE=
